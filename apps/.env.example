# The demo runs a LOCAL model (Ollama) — no API key required.
# Copy to apps/.env only if you want to override the defaults.

# By default the agent uses your HOST Ollama with llama3.2:1b.
# Make sure it's running and pulled:  ollama pull llama3.2:1b
# A 3B/7B model reasons noticeably better (1B over-calls tools).
# OLLAMA_MODEL=llama3.2:1b
# OLLAMA_URL=http://host.docker.internal:11434

# To use the self-contained model container instead of host Ollama:
#   docker compose --profile bundled-model up -d
#   OLLAMA_URL=http://ollama:11434
